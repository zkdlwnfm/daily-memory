<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Photos directory inside internal storage -->
    <files-path
        name="photos"
        path="photos/" />

    <!-- Thumbnails directory inside internal storage -->
    <files-path
        name="thumbnails"
        path="thumbnails/" />

    <!-- Cache directory for temporary files -->
    <cache-path
        name="cache"
        path="/" />
</paths>
