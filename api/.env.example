# Server
PORT=3000
NODE_ENV=production

# PostgreSQL (shared-db)
DB_HOST=192.168.50.201
DB_PORT=5432
DB_USERNAME=app_user
DB_PASSWORD=
DB_DATABASE=dailymemory

# Redis (shared-db)
REDIS_HOST=192.168.50.201
REDIS_PORT=6379
REDIS_PASSWORD=

# OpenAI
OPENAI_API_KEY=

# Firebase (path to service account JSON)
FIREBASE_SERVICE_ACCOUNT_PATH=/app/secrets/firebase-service-account.json

# Rate Limits (per day)
RATE_LIMIT_FREE_AI=30
RATE_LIMIT_FREE_IMAGE=10
RATE_LIMIT_FREE_EMBED=50
RATE_LIMIT_FREE_SEARCH=50
RATE_LIMIT_PREMIUM_AI=200
RATE_LIMIT_PREMIUM_IMAGE=100
RATE_LIMIT_PREMIUM_EMBED=500
RATE_LIMIT_PREMIUM_SEARCH=500
